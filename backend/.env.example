# ============================================================
# LLM Provider — выбери один: groq | gemini | ollama | openai | anthropic
# ============================================================
LLM_PROVIDER=groq

# --- Groq (рекомендуется для демо) ---
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (список моделей: https://ai.google.dev/gemini-api/docs/models)
GOOGLE_API_KEY=your-api-key-here
# Примеры: gemini-2.0-flash | gemini-2.5-flash | gemini-2.5-flash-lite (дешевле по квоте)
GOOGLE_MODEL=gemini-2.0-flash
# При 429 — число повторов с паузой (сервер сам ждёт retry_delay из ответа Google)
GEMINI_MAX_RETRIES=4
# Меньше символов в промпт — меньше токенов и нагрузка на free tier
TZ_SCORE_MAX_CHARS=8000

# --- Ollama (локально, без ключей) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# --- OpenAI (если есть ключ) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Anthropic Claude (если есть ключ) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================================
# Настройки сервера
# ============================================================
# JWT (для регистрации / истории анализов)
JWT_SECRET=замените-на-длинную-случайную-строку

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_FILE_SIZE_MB=50
