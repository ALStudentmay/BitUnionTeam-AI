# ============================================================
# LLM Provider — выбери один: gemini | ollama | openai | anthropic
# ============================================================
LLM_PROVIDER=gemini

# --- Google Gemini ---
GOOGLE_API_KEY=gen-lang-client-0391967847
GOOGLE_MODEL=gemini-1.5-pro

# --- Ollama (локально, без ключей) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# --- OpenAI (если есть ключ) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Anthropic Claude (если есть ключ) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================================
# Настройки сервера
# ============================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_FILE_SIZE_MB=50
